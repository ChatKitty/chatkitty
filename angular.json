{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "libraries",
  "projects": {
    "angular": {
      "projectType": "library",
      "root": "libraries/angular",
      "sourceRoot": "libraries/angular/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libraries/angular/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libraries/angular/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libraries/angular/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libraries/angular/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "303fa782-f66e-4797-a7bd-7c46db519135"
  }
}
