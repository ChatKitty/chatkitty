{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "examples",
  "projects": {
    "angular": {
      "projectType": "library",
      "root": "libraries/angular",
      "sourceRoot": "libraries/angular/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libraries/angular/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libraries/angular/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libraries/angular/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libraries/angular/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "angular-example": {
      "projectType": "application",
      "schematics": {},
      "root": "examples/angular-example",
      "sourceRoot": "examples/angular-example/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "examples/angular-example/dist",
            "index": "examples/angular-example/src/index.html",
            "browser": "examples/angular-example/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "examples/angular-example/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "examples/angular-example/public"
              }
            ],
            "styles": [
              "examples/angular-example/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "angular-example:build:production"
            },
            "development": {
              "buildTarget": "angular-example:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "examples/angular-example/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "examples/angular-example/public"
              }
            ],
            "styles": [
              "examples/angular-example/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "303fa782-f66e-4797-a7bd-7c46db519135"
  }
}
